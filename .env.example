# LLM Provider Configuration
# Choose which LLM provider to use: 'mock', 'grok', 'ollama', or 'null'
LLM_PROVIDER_TYPE=grok

# Grok API Configuration (required when LLM_PROVIDER_TYPE=grok)
# Get your API key from https://console.x.ai/
GROK_API_KEY=your_grok_api_key_here

# Ollama Configuration (required when LLM_PROVIDER_TYPE=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
