{
  "name": "agent_mcp_thoughtflow",
  "version": "1.8.0",
  "description": "Unified cognitive scaffold for LLM agents — structured reasoning (Tree of Thoughts), reliable execution (Task Orchestrator), and bidirectional bridge between thought and action.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "thoughtflow-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test test/bridge.test.ts",
    "test:llm": "node --test test/*.integration.test.ts",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build",
    "dashboard": "node dist/dashboard-server.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tree-of-thoughts",
    "task-orchestrator",
    "cognitive-scaffold",
    "ai-agents",
    "reasoning",
    "planning"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
